[Unit]
Description=Spow GUI Service
After=network.target

[Service]
# Replace 'omar' with your actual username
User=omar
WorkingDirectory=/Volumes/td rev/ta3al/windowstmacos
ExecStart=/usr/bin/python3 /Volumes/td rev/ta3al/windowstmacos/spow.py
Restart=always

# This environment variable is crucial for GUI apps
Environment=DISPLAY=:0

[Install]
WantedBy=multi-user.target
